PWM_D.peripheral.$assign = "TIMG0";
PWM_D.peripheral.ccp1Pin.$assign = "PA13";

SPI_LCD.$name = "SPI_LCD";
SPI_LCD.targetBitRate = 8000000;
SPI_LCD.frameFormat = "MOTO3";
SPI_LCD.peripheral.sclkPin.$assign = "PB9";
SPI_LCD.peripheral.mosiPin.$assign = "PB8";
SPI_LCD.peripheral.misoPin.$assign = "PB7";
SPI_LCD.sclkPinConfig.$name = "SPI_LCD_SCLK";
SPI_LCD.sclkPinConfig.direction = scripting.forceWrite("OUTPUT");
SPI_LCD.sclkPinConfig.onlyInternalResistor = scripting.forceWrite(false);
SPI_LCD.sclkPinConfig.passedPeripheralType = scripting.forceWrite("Digital");
SPI_LCD.mosiPinConfig.$name = "SPI_LCD_MOSI";
SPI_LCD.mosiPinConfig.direction = scripting.forceWrite("OUTPUT");
SPI_LCD.mosiPinConfig.hideOutputInversion = scripting.forceWrite(false);
SPI_LCD.mosiPinConfig.onlyInternalResistor = scripting.forceWrite(false);
SPI_LCD.mosiPinConfig.passedPeripheralType = scripting.forceWrite("Digital");
SPI_LCD.misoPinConfig.$name = "SPI_LCD_MISO_UNUSED";
SPI_LCD.misoPinConfig.onlyInternalResistor = scripting.forceWrite(false);
SPI_LCD.misoPinConfig.passedPeripheralType = scripting.forceWrite("Digital");

SYSCTL.clockTreeEn = true;
Board.peripheral.$suggestSolution = "DEBUGSS";
Board.peripheral.swclkPin.$suggestSolution = "PA20";
Board.peripheral.swdioPin.$suggestSolution = "PA19";
SPI_LCD.peripheral.$suggestSolution = "SPI1";
PWM_A.peripheral.$suggestSolution = "TIMA0";
PWM_C.peripheral.$suggestSolution = "TIMA1";
PWM_D.peripheral.$suggestSolution = "TIMG0";
