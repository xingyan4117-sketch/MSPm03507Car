PWM_A.peripheral.ccp3Pin.$assign = "PB13";

const PWM_C = PWM.addInstance();
PWM_C.$name = "PWM_C";
PWM_C.clockDivider = 2;
PWM_C.timerCount = 800;
PWM_C.ccIndex = [0];
