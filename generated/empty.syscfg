PWM_A.$name = "PWM_A";
PWM_A.clockDivider = 2;
PWM_A.timerCount = 800;
PWM_A.ccIndex = [2,3];
PWM_A.PWM_CHANNEL_2.$name = "ti_driverlib_pwm_PWMTimerCC2";
PWM_A.PWM_CHANNEL_3.$name = "ti_driverlib_pwm_PWMTimerCC3";
